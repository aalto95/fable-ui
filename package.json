{
  "name": "fable-ui-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "fable-ui:build": "pnpm --filter fable-ui build",
    "fable-ui:publish": "pnpm --filter fable-ui publish",
    "web:build": "pnpm --filter fable-ui-web build",
    "web:dev": "pnpm --filter fable-ui-web dev",
    "web:preview": "pnpm --filter fable-ui-web preview",
    "admin:build": "pnpm --filter fable-ui-admin build",
    "admin:dev": "pnpm --filter fable-ui-admin dev",
    "admin:format": "pnpm --filter fable-ui-admin format",
    "admin:lint": "pnpm --filter fable-ui-admin lint",
    "admin:preview": "pnpm --filter fable-ui-admin preview",
    "orchestrator:start": "pnpm --filter fable-ui-orchestrator start",
    "orchestrator:dev": "pnpm --filter fable-ui-orchestrator dev",
    "orchestrator:format": "pnpm --filter fable-ui-orchestrator format",
    "orchestrator:lint": "pnpm --filter fable-ui-orchestrator lint",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12"
  }
}
