{
  "name": "fable-ui-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "publish": "turbo run publish --filter=fable-ui",
    "publish:dry": "turbo run publish --filter=fable-ui -- --dry-run",
    "fable-ui:build": "turbo run build --filter=fable-ui",
    "fable-ui:publish": "pnpm --filter fable-ui publish",
    "shared:build": "turbo run build --filter=fable-shared",
    "shared:publish": "pnpm --filter=fable-shared publish",
    "web:build": "turbo run build --filter=fable-ui-web",
    "web:dev": "turbo run dev --filter=fable-ui-web",
    "web:preview": "turbo run preview --filter=fable-ui-web",
    "admin:build": "turbo run build --filter=fable-ui-admin",
    "admin:dev": "turbo run dev --filter=fable-ui-admin",
    "admin:format": "turbo run format --filter=fable-ui-admin",
    "admin:lint": "turbo run lint --filter=fable-ui-admin",
    "admin:preview": "turbo run preview --filter=fable-ui-admin",
    "orchestrator:start": "turbo run start --filter=fable-ui-orchestrator",
    "orchestrator:dev": "turbo run dev --filter=fable-ui-orchestrator",
    "orchestrator:format": "turbo run format --filter=fable-ui-orchestrator",
    "orchestrator:lint": "turbo run lint --filter=fable-ui-orchestrator",
    "vercel:web": "turbo run build --filter=...fable-ui-web",
    "vercel:admin": "turbo run build --filter=...fable-ui-admin",
    "vercel:orchestrator": "turbo run build --filter=...fable-ui-orchestrator",
    "lint": "biome check .",
    "format": "biome format --write .",
    "lint:turbo": "turbo run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "turbo": "catalog:"
  }
}
