{
  "name": "fable-ui-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter fable-ui build && pnpm --filter fable-ui-web build",
    "publish:fable-ui": "pnpm --filter fable-ui publish",
    "dev": "pnpm --filter fable-ui-web dev",
    "format": "biome format --write",
    "lint": "biome check",
    "preview": "pnpm --filter fable-ui-web preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10"
  }
}
