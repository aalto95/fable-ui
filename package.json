{
  "name": "manifest-ui-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter manifest-ui build && pnpm --filter manifest-ui-web build",
    "publish:manifest-ui": "pnpm --filter manifest-ui publish",
    "dev": "pnpm --filter manifest-ui-web dev",
    "format": "biome format --write",
    "lint": "biome check",
    "preview": "pnpm --filter manifest-ui-web preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8"
  }
}
