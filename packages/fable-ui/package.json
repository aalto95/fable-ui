{
  "name": "fable-ui",
  "version": "1.2.0",
  "description": "Fable UI: schema-driven React renderer for pages, forms, and pluggable components.",
  "keywords": [
    "react",
    "typescript",
    "ui",
    "schema",
    "renderer",
    "forms",
    "component-registry",
    "fable-ui",
    "declarative-ui",
    "layout"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "COMPONENTS.md",
    "CHANGELOG.md",
    "schema.json"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./register-async": {
      "types": "./dist/register-async.d.ts",
      "import": "./dist/register-async.js"
    },
    "./schema.json": "./schema.json",
    "./styles.css": "./src/styles/fable-ui.css",
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@fontsource-variable/geist": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "radix-ui": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.0",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "^4.5.4"
  }
}
