[
  {
    "route": "/",
    "name": "Home",
    "ui": [
      {
        "type": "table",
        "heads": [
          {
            "name": "name",
            "label": "Name",
            "type": "string"
          },
          {
            "name": "text",
            "label": "Text",
            "type": "string"
          },
          {
            "name": "dueDate",
            "label": "Due Date",
            "type": "date"
          }
        ],
        "dataSource": "http://localhost:3000/api/todo",
        "actions": [
          {
            "type": "GO_TO",
            "label": "Edit",
            "path": "/todo"
          }
        ]
      }
    ]
  },
  {
    "route": "/todo/create",
    "name": "Create Todo",
    "ui": [
      {
        "type": "form",
        "title": "Task Form",
        "method": "POST",
        "path": "http://localhost:3000/api/todo",
        "submitActions": [
          {
            "type": "GO_TO",
            "path": "/"
          }
        ],
        "fields": [
          {
            "type": "input",
            "name": "name",
            "label": "Enter task name",
            "required": true
          },
          {
            "type": "input",
            "name": "text",
            "label": "Enter task text",
            "required": true
          },
          {
            "type": "datepicker",
            "name": "dueDate",
            "label": "Enter due date"
          },
          {
            "type": "button",
            "text": "Save",
            "expand": true
          }
        ]
      }
    ]
  },
  {
    "route": "/todo/:id",
    "name": "Update Todo",
    "ui": [
      {
        "type": "form",
        "title": "Task Form",
        "method": "PUT",
        "path": "http://localhost:3000/api/todo",
        "submitActions": [
          {
            "type": "GO_TO",
            "path": "/"
          }
        ],
        "fields": [
          {
            "type": "input",
            "name": "name",
            "label": "Enter task name",
            "required": true
          },
          {
            "type": "input",
            "name": "text",
            "label": "Enter task text",
            "required": true
          },
          {
            "type": "datepicker",
            "name": "dueDate",
            "label": "Enter due date"
          },
          {
            "type": "button",
            "text": "Save",
            "expand": true
          }
        ]
      }
    ]
  }
]
