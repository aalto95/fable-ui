[
  {
    "route": "/",
    "ui": [
      {
        "id": "1",
        "type": "v_stack",
        "descendants": [
          {
            "id": "2",
            "type": "h_stack",
            "descendants": [
              {
                "id": "form",
                "type": "form",
                "method": "POST",
                "action": "http://localhost:3000/api/save",
                "descendants": [
                  {
                    "id": "name-input",
                    "type": "input",
                    "name": "name",
                    "label": "Enter your name",
                    "required": true
                  },
                  {
                    "id": "birthday-input",
                    "type": "datepicker",
                    "name": "birthday",
                    "label": "Enter your birthday",
                    "required": true
                  },
                  {
                    "id": "query-input",
                    "type": "select",
                    "name": "status",
                    "label": "Status of the user",
                    "required": true,
                    "options": [
                      { "label": "Active", "value": "active" },
                      { "label": "Inactive", "value": "inactive" }
                    ]
                  },
                  {
                    "id": "description-textarea",
                    "type": "textarea",
                    "name": "description",
                    "label": "Enter the description",
                    "required": true
                  },
                  {
                    "id": "checkbox-input",
                    "type": "checkbox",
                    "name": "isAdmin",
                    "label": "Should user be an admin",
                    "actions": ["adminRole/toggle"]
                  },
                  {
                    "id": "admin-role-input",
                    "type": "input",
                    "name": "adminRole",
                    "label": "What role of admin?",
                    "hidden": true
                  },
                  {
                    "id": "save-button",
                    "type": "button",
                    "text": "Save",
                    "expand": true
                  }
                ]
              },
              {
                "id": "form-2",
                "type": "form",
                "method": "POST",
                "action": "http://localhost:3000/api/save",
                "descendants": [
                  {
                    "id": "name-input-2",
                    "type": "input",
                    "name": "name-2",
                    "label": "Enter your name",
                    "defaultValue": "John",
                    "required": true
                  },
                  {
                    "id": "birthday-input-2",
                    "type": "datepicker",
                    "name": "birthday-2",
                    "label": "Enter your birthday",
                    "defaultValue": "2026-03-19T10:00:00Z",
                    "required": true
                  },
                  {
                    "id": "query-input-2",
                    "type": "select",
                    "name": "status-2",
                    "label": "Status of the user",
                    "required": true,
                    "options": [
                      { "label": "Active", "value": "active" },
                      { "label": "Inactive", "value": "inactive" }
                    ],
                    "defaultValue": "inactive"
                  },
                  {
                    "id": "description-textarea-2",
                    "type": "textarea",
                    "name": "description-2",
                    "label": "Enter the description",
                    "required": true,
                    "defaultValue": "This is a description"
                  },
                  {
                    "id": "checkbox-input-2",
                    "type": "checkbox",
                    "name": "superuser-2",
                    "label": "Should user be an admin",
                    "checked": true,
                    "actions": ["adminRole-2/toggle"]
                  },
                  {
                    "id": "admin-role-input-2",
                    "type": "input",
                    "name": "adminRole-2",
                    "label": "What role of admin?"
                  },
                  {
                    "id": "save-button-2",
                    "type": "button",
                    "text": "Save",
                    "expand": true
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "route": "/showcase",
    "ui": [
      {
        "id": "showcase-root",
        "type": "v_stack",
        "descendants": [
          {
            "id": "showcase-hero-row",
            "type": "h_stack",
            "descendants": [
              {
                "id": "hero-card",
                "type": "card",
                "title": "BDUI Showcase",
                "description": "A single screen that exercises stacks, cards, buttons, inputs, selects, textareas, forms, required validation, and the submit confirmation dialog.",
                "footerText": "Tip: try submitting each form to see the confirm dialog.",
                "descendants": [
                  {
                    "id": "hero-btn-1",
                    "type": "button",
                    "text": "Primary action"
                  },
                  {
                    "id": "hero-btn-2",
                    "type": "button",
                    "text": "Secondary action"
                  }
                ]
              },
              {
                "id": "hero-card-2",
                "type": "card",
                "title": "Nested layout",
                "description": "This card contains a nested vertical stack and a mini form.",
                "footerText": "Everything below is rendered from ui.json",
                "descendants": [
                  {
                    "id": "nested-v",
                    "type": "v_stack",
                    "descendants": [
                      {
                        "id": "mini-form",
                        "type": "form",
                        "method": "GET",
                        "action": "/api/search",
                        "descendants": [
                          {
                            "id": "mini-query",
                            "type": "input",
                            "name": "q",
                            "label": "Quick search (required)",
                            "required": true
                          },
                          {
                            "id": "mini-submit",
                            "type": "button",
                            "text": "Go"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "showcase-forms-row",
            "type": "h_stack",
            "descendants": [
              {
                "id": "post-form-card",
                "type": "card",
                "title": "POST form (JSON body)",
                "description": "Required fields + native select + textarea. Submitting prompts for confirmation.",
                "footerText": "Action points to the mock API save endpoint.",
                "descendants": [
                  {
                    "id": "post-form",
                    "type": "form",
                    "method": "POST",
                    "action": "http://localhost:3000/api/save",
                    "descendants": [
                      {
                        "id": "post-name",
                        "type": "input",
                        "name": "name",
                        "label": "Name (required)",
                        "required": true
                      },
                      {
                        "id": "post-status",
                        "type": "select",
                        "name": "status",
                        "label": "Status (required)",
                        "required": true,
                        "options": [
                          { "label": "Active", "value": "active" },
                          { "label": "Inactive", "value": "inactive" },
                          { "label": "Pending", "value": "pending" }
                        ]
                      },
                      {
                        "id": "post-desc",
                        "type": "textarea",
                        "name": "description",
                        "label": "Description (required)",
                        "required": true
                      },
                      {
                        "id": "post-submit",
                        "type": "button",
                        "text": "Submit POST"
                      }
                    ]
                  }
                ]
              },
              {
                "id": "get-form-card",
                "type": "card",
                "title": "GET form (query params)",
                "description": "Demonstrates URL building from form fields.",
                "footerText": "Try selecting a resource then submitting.",
                "descendants": [
                  {
                    "id": "get-form",
                    "type": "form",
                    "method": "GET",
                    "action": "/api/search",
                    "descendants": [
                      {
                        "id": "get-resource",
                        "type": "select",
                        "name": "q",
                        "label": "Resource (required)",
                        "required": true,
                        "options": [
                          { "label": "Users", "value": "users" },
                          { "label": "Posts", "value": "posts" },
                          { "label": "Comments", "value": "comments" }
                        ]
                      },
                      {
                        "id": "get-filter",
                        "type": "input",
                        "name": "filter",
                        "label": "Optional filter (e.g. id=1)"
                      },
                      {
                        "id": "get-submit",
                        "type": "button",
                        "text": "Submit GET"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "showcase-mixed-row",
            "type": "h_stack",
            "descendants": [
              {
                "id": "content-card-1",
                "type": "card",
                "title": "Card composition",
                "description": "Cards can include arbitrary descendants like buttons and inputs.",
                "footerText": "This is purely presentational content.",
                "descendants": [
                  {
                    "id": "content-input",
                    "type": "input",
                    "name": "demo",
                    "label": "An input living inside a card"
                  },
                  {
                    "id": "content-btn",
                    "type": "button",
                    "text": "Card button"
                  }
                ]
              },
              {
                "id": "content-card-2",
                "type": "card",
                "title": "Deep nesting",
                "description": "A stack inside a card inside a stack.",
                "footerText": "Useful for complex pages.",
                "descendants": [
                  {
                    "id": "deep-h",
                    "type": "h_stack",
                    "descendants": [
                      {
                        "id": "deep-left",
                        "type": "v_stack",
                        "descendants": [
                          {
                            "id": "deep-btn-1",
                            "type": "button",
                            "text": "Left 1",
                            "expand": false
                          },
                          {
                            "id": "deep-btn-2",
                            "type": "button",
                            "text": "Left 2"
                          }
                        ]
                      },
                      {
                        "id": "deep-right",
                        "type": "v_stack",
                        "descendants": [
                          {
                            "id": "deep-btn-3",
                            "type": "button",
                            "text": "Right 1"
                          },
                          {
                            "id": "deep-btn-4",
                            "type": "button",
                            "text": "Right 2"
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
]
