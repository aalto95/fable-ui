[
  {
    "route": "/",
    "name": "Home",
    "ui": [
      {
        "type": "v_stack",
        "descendants": [
          {
            "type": "table",
            "heads": [
              { "name": "name", "label": "Name", "type": "string" },
              { "name": "text", "label": "Text", "type": "string" },
              { "name": "dueDate", "label": "Due Date", "type": "date" }
            ],
            "dataSource": "http://localhost:3000/api/todo",
            "pageParam": "page",
            "limitParam": "limit",
            "defaultLimit": 10,
            "actions": [
              {
                "type": "GO_TO",
                "label": "Edit",
                "path": "/todo"
              },
              {
                "type": "HTTP_DELETE",
                "label": "Delete",
                "variant": "destructive",
                "path": "http://localhost:3000/api/todo"
              }
            ]
          },
          {
            "type": "button",
            "text": "Create Todo",
            "actions": [
              {
                "type": "GO_TO",
                "label": "Create Todo",
                "path": "/todo/create"
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "route": "/todo/create",
    "name": "Create Todo",
    "ui": [
      {
        "type": "form",
        "title": "Task Form",
        "fields": [
          {
            "type": "input",
            "name": "name",
            "label": "Enter task name",
            "required": true
          },
          {
            "type": "input",
            "name": "text",
            "label": "Enter task text",
            "required": true
          },
          {
            "type": "datepicker",
            "name": "dueDate",
            "label": "Enter due date"
          },
          {
            "type": "button",
            "text": "Save",
            "actions": [
              {
                "type": "HTTP_POST",
                "label": "Create",
                "path": "http://localhost:3000/api/todo"
              },
              {
                "type": "GO_TO",
                "label": "Home",
                "path": "/"
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "route": "/todo/:id",
    "name": "Update Todo",
    "ui": [
      {
        "type": "form",
        "title": "Task Form",
        "dataSource": "http://localhost:3000/api/todo",
        "fields": [
          {
            "type": "input",
            "name": "name",
            "label": "Enter task name",
            "required": true
          },
          {
            "type": "input",
            "name": "text",
            "label": "Enter task text",
            "required": true
          },
          {
            "type": "datepicker",
            "name": "dueDate",
            "label": "Enter due date"
          },
          {
            "type": "h_stack",
            "descendants": [
              {
                "type": "button",
                "text": "Cancel",
                "variant": "outline",
                "actions": [
                  {
                    "type": "GO_TO",
                    "label": "Home",
                    "path": "/"
                  }
                ]
              },
              {
                "type": "button",
                "text": "Update",
                "actions": [
                  {
                    "type": "HTTP_PUT",
                    "label": "Update",
                    "path": "http://localhost:3000/api/todo"
                  },
                  {
                    "type": "GO_TO",
                    "label": "Home",
                    "path": "/"
                  }
                ]
              },
              {
                "type": "button",
                "text": "Delete",
                "variant": "destructive",
                "actions": [
                  {
                    "type": "HTTP_DELETE",
                    "label": "Delete",
                    "path": "http://localhost:3000/api/todo"
                  },
                  {
                    "type": "GO_TO",
                    "label": "Home",
                    "path": "/"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "route": "/showcase",
    "name": "Advanced showcase",
    "ui": [
      {
        "type": "v_stack",
        "descendants": [
          {
            "type": "card",
            "title": "Server-driven UI showcase",
            "description": "This page exercises every registered component: card, horizontal and vertical stacks, accordion, table (with optional pagination), form, and all leaf inputs.",
            "footerText": "Toggle debug mode in the header to see component boundaries."
          },
          {
            "type": "accordion",
            "items": [
              {
                "name": "acc-layout",
                "title": "Layout primitives",
                "text": "v_stack and h_stack map to flex column and row. card groups title, description, footer, and nested descendants."
              },
              {
                "name": "acc-data",
                "title": "Data & navigation",
                "text": "table loads remote rows via dataSource with route query params (page/limit). pagination appears when the list response includes totalPages (or total + limit). forms use dataSource only for GET prefill on edit; all HTTP writes use button actions (POST, PUT, DELETE, GO_TO)."
              },
              {
                "name": "acc-leaf",
                "title": "Leaf components",
                "text": "input, textarea, select, datepicker, checkbox, and button are composed inside forms or standalone for demos."
              }
            ]
          },
          {
            "type": "h_stack",
            "descendants": [
              {
                "type": "card",
                "title": "Column A",
                "description": "Horizontal stack places cards side by side (on wide viewports).",
                "descendants": [
                  {
                    "type": "checkbox",
                    "name": "demo-a",
                    "label": "Standalone checkbox (not inside a form)"
                  },
                  {
                    "type": "button",
                    "text": "Primary-style button",
                    "expand": true
                  }
                ]
              },
              {
                "type": "card",
                "title": "Column B",
                "description": "Mix of controls without a form wrapper.",
                "descendants": [
                  {
                    "type": "input",
                    "name": "demo-input",
                    "label": "Standalone text input",
                    "defaultValue": "Editable default"
                  },
                  {
                    "type": "textarea",
                    "name": "demo-textarea",
                    "label": "Standalone textarea",
                    "defaultValue": "Multi-line text"
                  }
                ]
              }
            ]
          },
          {
            "type": "card",
            "title": "Remote table",
            "description": "Same todo API as the home page.",
            "descendants": [
              {
                "type": "table",
                "heads": [
                  { "name": "name", "label": "Name", "type": "string" },
                  { "name": "text", "label": "Text", "type": "string" },
                  { "name": "dueDate", "label": "Due", "type": "date" }
                ],
                "dataSource": "http://localhost:3000/api/todo",
                "pageParam": "showcasePage",
                "limitParam": "showcaseLimit",
                "defaultLimit": 4,
                "actions": [
                  {
                    "type": "GO_TO",
                    "label": "Edit",
                    "path": "/todo"
                  }
                ]
              }
            ]
          },
          {
            "type": "card",
            "title": "Form with every field type",
            "description": "POST creates a todo via the submit button actions; confirm in the dialog before the request runs.",
            "descendants": [
              {
                "type": "form",
                "title": "Create task (showcase)",
                "fields": [
                  {
                    "type": "input",
                    "name": "name",
                    "label": "Task name",
                    "required": true
                  },
                  {
                    "type": "textarea",
                    "name": "text",
                    "label": "Description",
                    "required": true
                  },
                  {
                    "type": "select",
                    "name": "priority",
                    "label": "Priority",
                    "required": false,
                    "options": [
                      { "label": "Low", "value": "low" },
                      { "label": "Medium", "value": "medium" },
                      { "label": "High", "value": "high" }
                    ]
                  },
                  {
                    "type": "datepicker",
                    "name": "dueDate",
                    "label": "Due date"
                  },
                  {
                    "type": "checkbox",
                    "name": "notify",
                    "label": "Send reminder",
                    "checked": false
                  },
                  {
                    "type": "button",
                    "text": "Submit showcase form",
                    "expand": true,
                    "actions": [
                      {
                        "type": "HTTP_POST",
                        "label": "Create",
                        "path": "http://localhost:3000/api/todo"
                      },
                      {
                        "type": "GO_TO",
                        "label": "Back to list",
                        "path": "/"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
]
