# --- PostgreSQL (direct SQL, migrations, ui_specs tables) ---
# Option A: single URL
# DATABASE_URL=postgresql://user:pass@host:5432/postgres

# Option B: Supabase (from dashboard / CLI — same names as .env.local)
# Prefer non-pooling for DDL-heavy workloads; pooler is fine for app traffic (prepare: false is set automatically).
# POSTGRES_URL_NON_POOLING=postgres://...
# POSTGRES_URL=postgres://...pooler...:6543/...
# POSTGRES_PRISMA_URL=postgres://...

# Optional pool tuning (see src/db/postgres.ts)
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_SEC=20
# PG_CONNECT_TIMEOUT_SEC=10

# --- Supabase JS client (PostgREST: .from().select(), auth, etc.) ---
# SUPABASE_URL=https://xxxx.supabase.co
# Or use the Next-style name:
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
