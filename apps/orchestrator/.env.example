# Required. UI specs and schema override are stored in PostgreSQL.
# Example: postgresql://user:pass@localhost:5432/sdui
# Copy to `.env` or use `.env.development` (loaded in dev when NODE_ENV is not production).
DATABASE_URL=

# Optional pool tuning (see src/db/postgres.ts)
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_SEC=20
# PG_CONNECT_TIMEOUT_SEC=10
